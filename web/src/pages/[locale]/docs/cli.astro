---
import DocsBaseLayout from "../../../components/docs/DocsBaseLayout.astro";
import DocsLayout from "../../../components/docs/DocsLayout.astro";
import DocsToc from "../../../components/docs/DocsToc.astro";
import DocsCliPage from "../../../components/docs/pages/DocsCliPage.astro";
import { ts, SUPPORTED_LOCALES, DEFAULT_LOCALE, type Locale } from "../../../i18n";

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== DEFAULT_LOCALE)
    .map((locale) => ({ params: { locale }, props: { locale } }));
}

const locale = (Astro.props.locale ?? DEFAULT_LOCALE) as Locale;

const tocItems = [
  { id: "cli-run", label: "ccpoke" },
  { id: "cli-setup", label: "setup" },
  { id: "cli-project", label: "project" },
  { id: "cli-update", label: "update" },
  { id: "cli-uninstall", label: "uninstall" },
  { id: "cli-help", label: "help" },
];
---

<DocsBaseLayout locale={locale} currentPage="cli" title={`CLI Reference — ${ts(locale, "docsTitle")}`}>
  <DocsLayout locale={locale} currentPage="cli">
    <DocsCliPage locale={locale} />
    <DocsToc locale={locale} items={tocItems} slot="toc" />
  </DocsLayout>
</DocsBaseLayout>
