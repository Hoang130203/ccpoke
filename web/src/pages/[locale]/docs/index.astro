---
import DocsBaseLayout from "../../../components/docs/DocsBaseLayout.astro";
import DocsLayout from "../../../components/docs/DocsLayout.astro";
import DocsToc from "../../../components/docs/DocsToc.astro";
import DocsOverviewPage from "../../../components/docs/pages/DocsOverviewPage.astro";
import { ts, SUPPORTED_LOCALES, DEFAULT_LOCALE, type Locale } from "../../../i18n";

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== DEFAULT_LOCALE)
    .map((locale) => ({ params: { locale }, props: { locale } }));
}

const locale = (Astro.props.locale ?? DEFAULT_LOCALE) as Locale;

const tocItems = [
  { id: "overview", label: ts(locale, "docsSidebarOverview") },
  { id: "getting-started", label: ts(locale, "docsSidebarGettingStarted") },
];
---

<DocsBaseLayout locale={locale} currentPage="">
  <DocsLayout locale={locale} currentPage="">
    <DocsOverviewPage locale={locale} />
    <DocsToc locale={locale} items={tocItems} slot="toc" />
  </DocsLayout>
</DocsBaseLayout>
