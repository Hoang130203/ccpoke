---
interface Props {
  sectionId: string;
  command: string;
  description: string;
  whenToUse: string;
  terminal?: string;
}

const { sectionId, command, description, whenToUse, terminal } = Astro.props;
---

<div class="cmd-block" id={sectionId}>
  <p class="cmd-block__title">$ {command}</p>
  <p class="cmd-block__desc" set:html={description} />
  <p class="cmd-block__when">
    <svg class="cmd-block__when-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="12" y1="16" x2="12" y2="12"></line>
      <line x1="12" y1="8" x2="12.01" y2="8"></line>
    </svg>
    <span>{whenToUse}</span>
  </p>
  {terminal && (
    <div class="docs-terminal-wrap">
      <button class="docs-terminal-copy" type="button" aria-label="Copy to clipboard" data-copy-target>
        <svg class="docs-terminal-copy__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <svg class="docs-terminal-copy__check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </button>
      <pre class="cmd-block__terminal">{terminal}</pre>
    </div>
  )}
</div>
