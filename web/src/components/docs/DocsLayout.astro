---
import DocsSidebar from "./DocsSidebar.astro";
import { type Locale } from "../../i18n";

interface Props {
  locale: Locale;
  currentPage: string;
}

const { locale, currentPage } = Astro.props;
---

<div class="docs-layout">
  <DocsSidebar locale={locale} currentPage={currentPage} />

  <button class="docs-layout__sidebar-toggle" id="docsSidebarToggle" type="button" aria-label="Toggle sidebar">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
  </button>
  <div class="docs-layout__overlay" id="docsSidebarOverlay"></div>

  <main class="docs-layout__main">
    <slot />
  </main>

  <slot name="toc" />
</div>

<button class="docs-scroll-top" id="docsScrollTop" type="button" aria-label="Scroll to top">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="18 15 12 9 6 15"></polyline>
  </svg>
</button>

<script>
  const toggle = document.getElementById("docsSidebarToggle");
  const overlay = document.getElementById("docsSidebarOverlay");
  const sidebar = document.querySelector(".docs-sidebar") as HTMLElement | null;

  function openSidebar() {
    sidebar?.classList.add("docs-sidebar--open");
    overlay?.classList.add("docs-layout__overlay--visible");
  }

  function closeSidebar() {
    sidebar?.classList.remove("docs-sidebar--open");
    overlay?.classList.remove("docs-layout__overlay--visible");
  }

  toggle?.addEventListener("click", openSidebar);
  overlay?.addEventListener("click", closeSidebar);

  sidebar?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeSidebar);
  });

  const scrollTopBtn = document.getElementById("docsScrollTop");
  let scrollTicking = false;

  document.addEventListener("scroll", () => {
    if (!scrollTicking) {
      requestAnimationFrame(() => {
        if (scrollTopBtn) {
          scrollTopBtn.classList.toggle("docs-scroll-top--visible", window.scrollY > 400);
        }
        scrollTicking = false;
      });
      scrollTicking = true;
    }
  }, { passive: true });

  scrollTopBtn?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  document.querySelectorAll<HTMLButtonElement>("[data-copy-target]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const pre = btn.closest(".docs-terminal-wrap")?.querySelector("pre");
      if (!pre) return;
      const text = pre.textContent ?? "";
      navigator.clipboard.writeText(text).then(() => {
        btn.classList.add("docs-terminal-copy--copied");
        setTimeout(() => btn.classList.remove("docs-terminal-copy--copied"), 1500);
      });
    });
  });
</script>
